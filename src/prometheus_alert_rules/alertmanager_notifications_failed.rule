groups:
- name: AlertmanagerNotificationsFailed
  rules:
  - alert: AlertmanagerNotificationsFailed
    expr: increase(alertmanager_notifications_failed_total[5m]) > 5
    for: 10m
    labels:
      severity: warning
    annotations:
      summary: Alertmanager notifications failure (application {{ $labels.juju_application }} in model {{ $labels.juju_model }})
      description: |
        Alertmanager notifications failure
        VALUE = {{ $value }}
        LABELS = {{ $labels }}
